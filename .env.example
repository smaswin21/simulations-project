# MongoDB
MONGODB_URI=mongodb://localhost:27017

# LLM provider selection
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:9b

# Hosted provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Provider-specific optional settings
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_EFFORT=low
GEMINI_THINKING_LEVEL=low
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Generation defaults
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=200
MAX_CONCURRENT_AGENTS=5

# Embedding and retrieval tuning
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RECENCY_DECAY=0.15
RETRIEVAL_TOP_K=7
BELIEF_ALIGNMENT_BOOST=1.5

# Contradiction and memory controls
COSINE_CONTRADICT_THRESHOLD=0.30
CONTRADICTION_BONUS=1.5
EXPANSION_BONUS=1.1
USE_LLM_CONTRADICTION=false
USE_LAYER2_MEMORY=true

# Simulation defaults
SIMULATION_SEED=42
NUM_ROUNDS=15
SPEECH_HISTORY_ROUNDS=2
